<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register — Auction House</title>
    <script>(function(){ document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'light') })()</script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root, [data-theme="light"] {
            --bg:        #f7f5f0;
            --bg-card:   #ffffff;
            --bg-input:  #f0ede6;
            --text:      #1a1a1a;
            --text-muted:#888;
            --border:    #e2ddd4;
            --gold:      #c9a84c;
            --gold-text: #8a6820;
            --gold-glow: rgba(201,168,76,0.18);
            --shadow:    0 4px 24px rgba(0,0,0,0.08);
        }
        [data-theme="dark"] {
            --bg:        #0a0a0f;
            --bg-card:   #12121a;
            --bg-input:  #0a0a0f;
            --text:      #e8e8e8;
            --text-muted:#555;
            --border:    #1e1e2e;
            --gold:      #c9a84c;
            --gold-text: #c9a84c;
            --gold-glow: rgba(201,168,76,0.18);
            --shadow:    0 4px 40px rgba(0,0,0,0.55);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif;
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            padding: 1.5rem; transition: background .25s, color .25s;
        }
        .theme-btn {
            position: fixed; top: 1rem; right: 1rem;
            background: none; border: 1px solid var(--border); color: var(--text-muted);
            width: 34px; height: 34px; border-radius: 50%; font-size: 1rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: border-color .2s, color .2s;
        }
        .theme-btn:hover { border-color: var(--gold); color: var(--gold); }
        .auth-card {
            width: 100%; max-width: 400px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-top: 2px solid var(--gold);
            border-radius: 8px;
            padding: 2.5rem 2rem;
            box-shadow: var(--shadow);
        }
        .auth-logo {
            font-size: .82rem; font-weight: 700; letter-spacing: .35em;
            color: var(--gold-text); text-transform: uppercase;
            text-align: center; margin-bottom: 1.75rem;
        }
        .auth-title {
            font-size: 1.3rem; font-weight: 600; color: var(--text);
            text-align: center; margin-bottom: 1.75rem;
        }
        .error {
            background: rgba(200,40,40,0.08); border: 1px solid rgba(200,40,40,0.22);
            color: #c0392b; border-radius: 4px; padding: .65rem .9rem;
            font-size: .85rem; margin-bottom: 1.25rem;
        }
        [data-theme="dark"] .error { background: rgba(200,40,40,0.1); border-color: rgba(200,40,40,0.3); color: #e07070; }
        label {
            display: block; font-size: .72rem; font-weight: 600;
            letter-spacing: .08em; text-transform: uppercase;
            color: var(--text-muted); margin-bottom: .35rem;
        }
        input {
            width: 100%; padding: .8rem 1rem;
            background: var(--bg-input); border: 1px solid var(--border);
            border-radius: 5px; color: var(--text);
            font-family: 'Inter', sans-serif; font-size: .95rem;
            margin-bottom: 1.1rem; outline: none;
            transition: border-color .2s, box-shadow .2s;
        }
        input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-glow); }
        input::placeholder { color: var(--border); }
        button[type="submit"] {
            width: 100%; padding: .88rem;
            background: var(--gold); color: #1a1a1a;
            border: none; border-radius: 5px;
            font-family: 'Inter', sans-serif; font-size: .95rem; font-weight: 700;
            letter-spacing: .04em; cursor: pointer; margin-top: .25rem;
            transition: opacity .2s, box-shadow .2s;
        }
        button[type="submit"]:hover { opacity: .88; box-shadow: 0 0 18px var(--gold-glow); }
        .link { margin-top: 1.5rem; text-align: center; font-size: .84rem; color: var(--text-muted); }
        .link a { color: var(--gold-text); text-decoration: none; font-weight: 500; }
        .link a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <button class="theme-btn" id="theme-btn" onclick="toggleTheme()" title="Toggle theme"></button>
    <div class="auth-card">
        <div class="auth-logo">Auction House</div>
        <h1 class="auth-title">Create Account</h1>
        <% if (error) { %><div class="error"><%= error %></div><% } %>
        <form method="POST" action="/register">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
            <label for="username">Username</label>
            <input type="text" id="username" name="username" required>
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required>
            <button type="submit">Register</button>
        </form>
        <p class="link"><a href="/login">Already have an account?</a></p>
    </div>
    <script>
        function toggleTheme() {
            const html = document.documentElement
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
            html.setAttribute('data-theme', next)
            localStorage.setItem('theme', next)
            document.getElementById('theme-btn').textContent = next === 'dark' ? '☀' : '☾'
        }
        document.getElementById('theme-btn').textContent =
            document.documentElement.getAttribute('data-theme') === 'dark' ? '☀' : '☾'
    </script>
</body>
</html>
