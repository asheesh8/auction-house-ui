<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auctions — Auction House</title>
    <style>
        body { font-family: sans-serif; max-width: 800px; margin: 40px auto; padding: 0 1rem; }
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
        h1 { margin: 0; }
        .logout { background: none; border: 1px solid #333; padding: .4rem .8rem; cursor: pointer; }
        .auction-list { list-style: none; padding: 0; margin: 0; }
        .auction-list li { border: 1px solid #ddd; padding: 1rem; margin-bottom: .75rem; border-radius: 4px; }
        .auction-list li a { text-decoration: none; color: #333; font-size: 1.1rem; font-weight: bold; }
        .auction-list li a:hover { text-decoration: underline; }
        .meta { color: #666; font-size: .9rem; margin-top: .25rem; }
        .empty { color: #999; }
    </style>
</head>
<body>
    <header>
        <h1>Active Auctions</h1>
        <form method="POST" action="/logout">
            <button class="logout" type="submit">Log out (<%= user.username %>)</button>
        </form>
    </header>

    <% if (auctions.length === 0) { %>
        <p class="empty">No active auctions right now.</p>
    <% } else { %>
        <ul class="auction-list">
            <% auctions.forEach(a => { %>
            <li>
                <a href="/auctions/<%= a.id %>"><%= a.item_name %></a>
                <div class="meta">
                    Top bid: $<%= a.top_bid.toFixed(2) %> &nbsp;|&nbsp;
                    Ends: <%= new Date(a.end_date).toLocaleDateString() %>
                    <% if (a.description && a.description.length > 0) { %> &nbsp;|&nbsp; <%= a.description %><% } %>
                </div>
            </li>
            <% }) %>
        </ul>
    <% } %>
</body>
</html>
